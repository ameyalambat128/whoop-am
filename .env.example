# Whoop OAuth
# 1. Go to https://developer.whoop.com/ and create a new application
# 2. Set the redirect URI to http://localhost:3000/callback
# 3. Copy your client ID and secret below
# 4. Run: bun run auth
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_REDIRECT_URI=http://localhost:3000/callback

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Your phone number (the bot only responds to this number)
IMESSAGE_RECIPIENT=+1234567890

# Morning message schedule (cron syntax, default: 7 AM daily)
MORNING_MESSAGE_CRON=0 7 * * *

# AI model (default: claude-haiku-4-5-20251001, try claude-sonnet-4-5-20250929 for better vibes)
AI_MODEL=claude-haiku-4-5-20251001
